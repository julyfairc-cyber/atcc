[gd_scene format=3 uid="uid://cs0ibb0hoiskq"]

[sub_resource type="GDScript" id="GDScript_fmuat"]
resource_name = "item_menu"
script/source = "# item_menu.gd
extends CanvasLayer

@export var item_list_container: VBoxContainer
signal item_selected(item: ItemData)
signal closed

func open() -> void:
	_populate_items()

func _populate_items() -> void:
	for child in item_list_container.get_children():
		child.queue_free()

	for item in Inventory.items.keys():
		var qty = Inventory.items[item]
		var button = Button.new()
		button.text = \"%s x%d\" % [item.item_name, qty]
		button.pressed.connect(func(): _on_item_chosen(item))
		item_list_container.add_child(button)

func _on_item_chosen(item: ItemData) -> void:
	item_selected.emit(item)
	closed.emit()
	queue_free()
"

[node name="item_menu" type="CanvasLayer" unique_id=1355934624]
script = SubResource("GDScript_fmuat")

[node name="Panel" type="Panel" parent="." unique_id=1602754030]
